# ────────────────────────────────────────────────────────
#  Copia este archivo como .env y rellena tus valores
#  NUNCA subas el .env real a git
# ────────────────────────────────────────────────────────

# ── Pool de API Keys de Gemini ───────────────────────────
# Agrega hasta 9 claves gratuitas. El sistema las rota automáticamente
# cuando una se agota (límite diario: 1,500 requests/día por clave).
# Cada blog completo consume ~3 requests (1 por post).
GEMINI_API_KEY_1=AIzaSy_REEMPLAZA_CLAVE_1
GEMINI_API_KEY_2=AIzaSy_REEMPLAZA_CLAVE_2
GEMINI_API_KEY_3=AIzaSy_REEMPLAZA_CLAVE_3
# GEMINI_API_KEY_4=AIzaSy_REEMPLAZA_CLAVE_4  ← descomenta para añadir más

# ── Modo MOCK de Gemini ──────────────────────────────────
# true  → 0 tokens gastados, respuestas de prueba instantáneas
# false → llama a la API real (necesita al menos una GEMINI_API_KEY_N válida)
GEMINI_MOCK_MODE=true

# ── Modo de operación WordPress ──────────────────────────
# simulated → guarda drafts en JSON local (sin WordPress)
# live      → envía directamente a WordPress REST API
WP_MODE=simulated

# ── WordPress (solo necesario cuando WP_MODE=live) ───────
WP_BASE_URL=https://tu-blog.com
WP_USERNAME=tu_usuario_wordpress
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Amazon Affiliates ────────────────────────────────────
AMAZON_AFFILIATE_TAG=tu-tag-20

# ── Proxy corporativo (opcional) ─────────────────────────
# Rellena SOLO si estás en una red corporativa que bloquea googleapis.com
# (VPN, proxy de empresa, firewall corporativo, etc.)
# Ejemplo: HTTPS_PROXY=http://proxy.empresa.com:8080
HTTP_PROXY=
HTTPS_PROXY=
